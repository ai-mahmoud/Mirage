# Vite/rolldown want Node >=20.19 or >=22.12 — use 22 outright rather than
# fighting the engine warning on every build.
FROM node:22-slim AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install \
    # Known npm optional-dependency bug (npm/cli#4828): the platform-specific
    # rolldown native binding sometimes doesn't get installed. Cheap
    # insurance — no-op if it's already present.
    && npm install @rolldown/binding-linux-x64-gnu --no-save || true

COPY . .

ARG VITE_API_BASE_URL=http://localhost:8001
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
